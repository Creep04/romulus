{
  "mcpServers": {
    "screeps": {
      "command": "screeps-mcp-server",
      "env": {
        "SCREEPS_TOKEN": "$SCREEPS_TOKEN"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
